                    }
                  },
                  {
                    "when": "block=minecraft:mossy_stone_bricks",
                    "model": {
                      "type": "minecraft:model",
                      "model": "minecraft:hygrave/grave/decoration/slightly_rounded_square_shape/mossy_stone_bricks"
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/green_dye"
    }
  }
}
