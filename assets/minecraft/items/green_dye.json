                  {
                    "when": "block=minecraft:stone",
                    "model": {
                      "type": "minecraft:model",
                      "model": "minecraft:hygrave/grave/decoration/slightly_rounded_square_shape/stone"
                    }
                  },
                  {
                    "when": "block=minecraft:cobblestone",
                    "model": {
                      "type": "minecraft:model",
                      "model": "minecraft:hygrave/grave/decoration/slightly_rounded_square_shape/cobblestone"
                    }
                  },
                  {
                    "when": "block=minecraft:mossy_cobblestone",
                    "model": {
                      "type": "minecraft:model",
                      "model": "minecraft:hygrave/grave/decoration/slightly_rounded_square_shape/mossy_cobblestone"
                    }
