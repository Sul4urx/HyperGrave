                    "model": {
                      "type": "minecraft:model",
                      "model": "minecraft:hygrave/grave/decoration/top_rounded_square_shape/cobblestone"
                    }
                  },
                  {
                    "when": "block=minecraft:mossy_cobblestone",
                    "model": {
                      "type": "minecraft:model",
                      "model": "minecraft:hygrave/grave/decoration/top_rounded_square_shape/mossy_cobblestone"
                    }
                  },
                  {
                    "when": "block=minecraft:stone_bricks",
                    "model": {
                      "type": "minecraft:model",
                      "model": "minecraft:hygrave/grave/decoration/top_rounded_square_shape/stone_bricks"
                    }
                  },
                  {
                    "when": "block=minecraft:mossy_stone_bricks",
                    "model": {
                      "type": "minecraft:model",
                      "model": "minecraft:hygrave/grave/decoration/top_rounded_square_shape/mossy_stone_bricks"
                    }
                  }
                ]
              }
            },
            {
